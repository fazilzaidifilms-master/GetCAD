# GetCAD environment template. Copy to `.env.local` and fill in.
# NEVER commit real values. NEVER put a secret behind NEXT_PUBLIC_*.

# --- Clerk -> Supabase bridge (slice 3) ---
# Public, non-secret. Your Clerk Frontend API origin (the "Clerk Domain" you
# registered in Supabase -> Authentication -> Third-Party Auth).
#   dev:  https://your-app-xxxx.clerk.accounts.dev
#   prod: https://clerk.yourdomain.com
CLERK_JWT_ISSUER=

# Optional. Defaults to ${CLERK_JWT_ISSUER}/.well-known/jwks.json
# CLERK_JWKS_URL=

# --- Database (migrations / local tests) ---
# Used by `npm run db:apply` and the DB tests. For live Supabase use the
# Session pooler (IPv4) string; locally point at your throwaway Postgres.
# DATABASE_URL=postgresql://postgres:password@host:5432/postgres
